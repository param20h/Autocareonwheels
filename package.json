{
  "name": "car-service-monorepo",
  "version": "1.0.0",
  "description": "Car Service Booking Website Monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && rm -rf dist && cp -R client/dist dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "cloudinary": "2.9.0",
    "nodemailer": "^9.0.1"
  },
  "overrides": {
    "tar": "^7.5.16",
    "@mapbox/node-pre-gyp": {
      "tar": "^7.5.16"
    },
    "bcrypt": {
      "@mapbox/node-pre-gyp": "^2.0.3"
    },
    "server": {
      "tar": "^7.5.16",
      "@mapbox/node-pre-gyp": "^2.0.3"
    },
    "form-data": "^4.0.6",
    "shell-quote": "^1.8.4",
    "qs": "^6.15.2",
    "brace-expansion": "^5.0.6",
    "follow-redirects": "^1.16.0"
  }
}
