# General
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api/v1
BUSINESS_PHONE=

# Database
DATABASE_URL=

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# Admin bootstrap (used by server/createAdmin.js)
ADMIN_EMAIL=a
ADMIN_PASSWORD=A
ADMIN_NAME=S
ADMIN_PHONE=0

# SMTP (email utility)
SMTP_HOST=sm
SMTP_PORT=4
SMTP_USER=i
SMTP_PASS=PASTE_HOSTINGER_MAILBOX_PASSWORD_HERE
SMTP_FROM=
BUSINESS_EMAIL=
SEND_BOOKING_EMAILS=false

# Optional incoming mailbox settings (for reference)
IMAP_HOST=i
IMAP_PORT=9
POP_HOST=
POP_PORT=9

# Cloudinary (upload utility)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Push notifications (optional)
FCM_SERVER_KEY=
