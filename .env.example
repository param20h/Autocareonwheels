# General
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api/v1
BUSINESS_PHONE=YOUR_BUSINESS_PHONE

# Database
DATABASE_URL="sqlserver://localhost:1433;database=autocare_db;user=sa;password=YOUR_DB_PASSWORD;encrypt=true;trustServerCertificate=true"

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# Admin bootstrap (used by server/createAdmin.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_NAME=Admin User
ADMIN_PHONE=YOUR_ADMIN_PHONE

# SMTP (email utility)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=
SMTP_USER=your-email@your-domain.com
SMTP_PASS=PASTE_HOSTINGER_MAILBOX_PASSWORD_HERE
SMTP_FROM=your-email@your-domain.com
BUSINESS_EMAIL=your-email@your-domain.com
SEND_BOOKING_EMAILS=true

# Optional incoming mailbox settings (for reference)
IMAP_HOST=imap.your-provider.com
IMAP_PORT=
POP_HOST=pop.your-provider.com
POP_PORT=

# Cloudinary (upload utility)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Push notifications (optional)
FCM_SERVER_KEY=
